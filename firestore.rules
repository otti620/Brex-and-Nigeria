rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSystemServiceAccount() {
      return isSignedIn() && request.auth.token.email == 'backend-system-service-account@brex.internal';
    }

    match /{document=**} {
      allow read, write: if isSystemServiceAccount();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'email', 'name'])
        && data.id is string && data.id.size() <= 128
        && data.email is string && data.email.size() <= 256
        && data.name is string && data.name.size() <= 128;
    }

    function isValidTransaction(data) {
       return data.keys().hasAll(['id', 'userId', 'amount', 'type', 'status', 'date'])
        && data.id is string
        && data.userId is string
        && data.amount is number
        && data.type is string
        && data.status is string
        && data.date is string;
    }

    function isSystemAdmin() {
      return isSignedIn() && (
        (request.auth.token.email == 'ottigospel@gmail.com') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    // User Profile matching
    match /users/{userId} {
      function isReferral() {
        return isSignedIn() && (
          resource.data.referredBy == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.invitationCode ||
          resource.data.referrerUid == request.auth.uid
        );
      }

      allow read: if isOwner(userId) || isSystemAdmin() || isReferral();
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isOwner(userId) || isSystemAdmin();
      allow delete: if isSystemAdmin();
    }

    // User Lottery Tickets subcollection
    match /users/{userId}/lottery_tickets/{ticketId} {
      allow read: if isOwner(userId) || isSystemAdmin();
      allow create: if isSignedIn() && isOwner(userId);
      allow update, delete: if isSystemAdmin();
    }

    // User Transactions matching (supports collection group queries needed for the admin console)
    match /{path=**}/transactions/{transactionId} {
      allow read: if isSystemAdmin() || (
        isSignedIn() && resource != null && resource.data.userId == request.auth.uid
      );
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidTransaction(incoming());
      allow update: if isSystemAdmin();
      allow delete: if isSystemAdmin();
    }

    // Support ticket matching
    match /support_tickets/{ticketId} {
      allow create: if isSignedIn();
      allow read: if isSystemAdmin() || (resource != null && resource.data.userId == request.auth.uid);
      allow update: if isSystemAdmin();
      allow delete: if isSystemAdmin();
    }

    // Broadcast matching
    match /broadcasts/{broadcastId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSystemAdmin();
    }

    // Security & audit logs matching
    match /security_logs/{logId} {
      allow create: if isSignedIn();
      allow read: if isSystemAdmin();
      allow update, delete: if isSystemAdmin();
    }

    // Configurations matching
    match /config/{configId} {
      allow read: if isSignedIn();
      allow write: if isSystemAdmin();
    }
  }
}
